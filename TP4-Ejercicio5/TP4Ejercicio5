    public boolean validateTelefone(String telefone) {
        Pattern pattern = Pattern.compile("^(388)[0-9]{9}$");
        Matcher mather = pattern.matcher(telefone);
        if (mather.find()) {
            return false;
        } else {
            System.out.println("Error...");
            System.out.println("El Num. de Celular debe estar comprendido entre 12 cifras");
            System.out.println("EJ: 388154040314");
            return true;
        }
    }
 
    public boolean validateEmail(String mail) {
        Pattern pattern = Pattern.compile("^[_A-Za-z0-9-\\+]+(\\.[_A-Za-z0-9-]+)*@[A-Za-z0-9-]+(\\.[A-Za-z0-9]+)*(\\.[A-Za-z]{2,})$");
        Matcher mather = pattern.matcher(mail);
        if (mather.find()) {
            return false;
        } else {
            System.out.println("Error...");
            System.out.println("El mail ingresado es incorrecto");
            return true;
        }
    }
 
    public boolean validateName(String name) {
        int valueASCII;
        for (int i = 0; i < name.length(); i++) {
            valueASCII = (int) Character.toUpperCase(name.charAt(i));
            if (!((valueASCII >= 65 && valueASCII <= 90) || (valueASCII == ' '))) {
                System.out.println("Error...");
                System.out.println("El nombre ingresado esta mal escrito ");
                return true;
            }
        }
        return false;
    }
 
