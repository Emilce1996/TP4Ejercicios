    public void open() {
        char option;
        do {
            System.out.println("Ejercicio Agenda");
            System.out.println("a) Carga manual de la agenda");
            System.out.println("b) Carga automatica de la agenda");
            System.out.println("c) Buscar por coincidencia");
            System.out.println("d) Mostrar agenda e informar trabajo/empresa dado");
            System.out.println("e) Salir");
            System.out.print("Ingresar opción: ");
            option = Helper.getChar();
        } while (run(option));
    }
 
    public boolean run(char option) {
        switch (Character.toUpperCase(option)) {
            case 'A' -> {
                if (getListSchedule().size()==0) {
                    registerManual();
                    return true;
                }else{
                    System.out.println("Ya hay contactos agregados, se van a agregar nuevos contactos.");
                    registerManual();
                    return true;
                }
            }
            case 'B' -> {
                if (getListSchedule().size()==0) {
                    registerAutomatic();
                    return true;
                }else{
                    System.out.println("Ya hay contactos generados, se van a generar nuevos contactos.");
                    registerAutomatic();
                    return true;
                }
            }
            case 'C' -> {
                if (getListSchedule().size()==0) {
                    System.out.println("Error...");
                    System.out.println("Debe agregar contactos primero!");
                    return true;
                } else {
                    search();
                    return true;
                }
            }
            case 'D' -> {
                if (getListSchedule().size()==0) {
                    System.out.println("No hay contactos agregados para mostrar.");
                    return true;
                }else{
                    showListScheduleInfo();
                    return true;
                }
            }
            case 'E' -> {
                return false;
            }
            default -> {
                System.out.println("Error...");
                System.out.println("Intentelo de nuevo!");
                return true;
            }
        }
    } 
    
    public void showListScheduleInfo(){
        int contJob=0;
        Iterator<Contact> iter = getListSchedule().iterator();
        System.out.print("Ingrese trabajo/empresa de contactos: ");
        String searchJob = Helper.getString();
        Contact contactIter;
        System.out.println("Se mostrara la lista de contactos: ");
        while(iter.hasNext()){
            contactIter=iter.next();
            System.out.println(contactIter);
            if(contactIter.getJob().toUpperCase().equals(searchJob.toUpperCase())){
                contJob++;
            }
        }
        System.out.println("Contactos que corresponden a "+searchJob+" : "+contJob);
    }
    
    public void search() {
        ILinkedList<Contact> listCoinciden = new SimpleLinkedList<>();
        Iterator<Contact> iter = getListSchedule().iterator();
        System.out.print("Ingrese busqueda: ");
        String searchName = Helper.getString();
        Contact contactIter;
        while (iter.hasNext()) {
            contactIter = iter.next();
            if (contactIter.getName().toUpperCase().contains(searchName.toUpperCase())) {
                listCoinciden.addFirst(contactIter);
            }
        }
        System.out.println(listCoinciden.size() != 0 ? "Nueva lista: \n" + listCoinciden : "No se encontraron coincidencias para " + searchName);
    }
 
